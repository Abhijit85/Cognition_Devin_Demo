# ---------- Devin API ----------
# Service user key (starts with cog_). Create one at:
#   Devin UI > Settings > Service Users
DEVIN_API_KEY=cog_replace_me

# Organization ID — visible on the same Settings > Service Users page.
DEVIN_ORG_ID=replace_me

# Set to 1 to use the in-process mock client (no API calls, no ACU spent).
# Useful for first-time setup and for evaluators without an account.
DEVIN_MOCK=0

# ---------- GitHub ----------
# Personal access token with `repo` scope on the fork of apache/superset.
GH_TOKEN=ghp_replace_me

# Your fork, e.g. Abhijit85/superset
GH_REPO=Abhijit85/superset

# Path to the local clone of the repo (mounted read-only into the container).
REPO_PATH=./superset

# ---------- Orchestrator tuning ----------
POLL_INTERVAL=30
ORCHESTRATOR_URL=http://localhost:8000
DATABASE_PATH=/data/orchestrator.db

# ---------- Cost model (dashboard) ----------
DEV_HOURLY_RATE=150
DEV_HOURS_PER_CVE_BASELINE=4
ACU_COST=2.25
